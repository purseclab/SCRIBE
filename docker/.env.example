# Copy to .env. Used by docker/build.sh and docker compose.

# Image tag suffix (build / pull). Pick one (e.g. arm32_O0, amd64_O0, latest).
TAG=latest

# IDA Pro paths inside the container. Only needed if you run
# scripts/decompile_func.py or scripts/dump_asm_and_decomp.py to regenerate
# from_decompiler/ snapshots. Bind-mount your install at runtime, e.g.:
#   -v /path/to/ida:/root/ida -v /path/to/.idapro:/root/.idapro
DECOMPILER_CONFIG_IDA_PATH=/root/ida
DECOMPILER_CONFIG_IDA_DEF_H_FILE_PATH=/root/ida/idapro/plugins/hexrays_sdk/include/defs.h
